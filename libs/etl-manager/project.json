{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "etl-manager",
  "sourceRoot": "libs/etl-manager/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/etl-manager",
        "main": "libs/etl-manager/src/index.ts",
        "tsConfig": "libs/etl-manager/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/etl-manager"],
      "options": {
        "jestConfig": "libs/etl-manager/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["scope:backend", "type:lib"]
}
